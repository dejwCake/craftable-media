{
    "name": "dejwcake/craftable-media",
    "description": "Associate files with Eloquent models",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "media",
        "medialibrary",
        "images",
        "cms",
        "laravel"
    ],
    "authors": [
        {
            "name": "David Běhal",
            "email": "david.behal@dejw.sk",
            "homepage": "https://www.dejw.sk",
            "role": "Developer"
        },
        {
            "name": "Pavol Perdík",
            "email": "pavol.perdik@brackets.sk",
            "homepage": "https://www.brackets.sk",
            "role": "Developer"
        },
        {
            "name": "Marek Kratochvíla",
            "email": "marek.kratochvila@brackets.sk",
            "homepage": "https://www.brackets.sk",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.5",
        "illuminate/support": "^13.0",
        "spatie/laravel-medialibrary": "^11.22"
    },
    "require-dev": {
        "larastan/larastan": "^3.9",
        "orchestra/testbench": "^11.1",
        "phpunit/phpunit": "^13.1"
    },
    "autoload": {
        "psr-4": {
            "Brackets\\Media\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Brackets\\Media\\Tests\\": "tests"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "2.0-dev",
            "dev-v2-dev": "2.0-dev"
        },
        "laravel": {
            "providers": [
                "Brackets\\Media\\MediaServiceProvider"
            ]
        }
    }
}
